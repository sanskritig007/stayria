<% if(success && success.length){%>
<div class="alert alert-dismissible fade show custom-flash-alert shadow-lg bg-white rounded-4" role="alert" style="position: fixed; top: 90px; left: 50%; transform: translateX(-50%); z-index: 1050; min-width: 320px; border: none; padding: 16px 24px;">
  <div class="d-flex align-items-center pe-4">
    <i class="fa-solid fa-circle-check me-2" style="color: #00a699; font-size: 1.25rem;"></i>
    <span class="flash-msg fw-medium text-dark" style="font-size: 0.95rem; letter-spacing: 0.3px;"><%= success%></span>
  </div>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="top: 50%; transform: translateY(-50%); right: 12px; padding: 0.5rem;"></button>
</div>
<%}%>

<% if(error && error.length){%>
<div class="alert alert-dismissible fade show custom-flash-alert shadow-lg bg-white rounded-4" role="alert" style="position: fixed; top: 90px; left: 50%; transform: translateX(-50%); z-index: 1050; min-width: 320px; border: none; padding: 16px 24px;">
  <div class="d-flex align-items-center pe-4">
    <i class="fa-solid fa-circle-exclamation me-2" style="color: #e61e4d; font-size: 1.25rem;"></i>
    <span class="flash-msg fw-medium text-dark" style="font-size: 0.95rem; letter-spacing: 0.3px;"><%= error%></span>
  </div>
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="top: 50%; transform: translateY(-50%); right: 12px; padding: 0.5rem;"></button>
</div>
<%}%>